{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/dangol-onboarding",
      "destination": "/start",
      "permanent": true
    },
    {
      "source": "/dangol-onboarding.html",
      "destination": "/start",
      "permanent": true
    },
    {
      "source": "/dangol-owner-flow",
      "destination": "/owner",
      "permanent": true
    },
    {
      "source": "/dangol-owner-flow.html",
      "destination": "/owner",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/s/:store_id",
      "destination": "/customer"
    }
  ]
}
